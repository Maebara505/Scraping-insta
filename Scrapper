def obtener_perfil_requests():
    """EXTRAE NOMBRE, BIO Y SEGUIDORES (DATOS DEL PERFIL)"""
    print(f"\n[1] Accediendo al perfil de {USERNAME} para extraer Bio y Nombre...")
    url = f"https://www.instagram.com/api/v1/users/web_profile_info/?username={USERNAME}"
    headers = {
        "user-agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
        "x-ig-app-id": "936619743392459"
    }

    perfil_info = []
    try:
        res = requests.get(url, headers=headers, cookies={'sessionid': SESSION_ID})
        if res.status_code == 200:
            data = res.json().get('data', {}).get('user', {})

            # Datos específicos solicitados
            nombre_completo = data.get('full_name', 'No encontrado')
            biografia = data.get('biography', 'No encontrado')
            seguidores = data.get('edge_followed_by', {}).get('count', 0)
            seguidos = data.get('edge_follow', {}).get('count', 0)

            print(f"    ✓ Nombre: {nombre_completo}")
            print(f"    ✓ Bio: {biografia}")

            perfil_info.append({
                'tipo_dato': 'INFORMACIÓN DEL PERFIL',
                'post_url': f"Nombre Completo: {nombre_completo}",
                'detalle': f"Biografía: {biografia}",
                'comment_1': f"Seguidores: {seguidores}",
                'comment_2': f"Seguidos: {seguidos}",
                'comment_3': 'N/A'
            })
        else:
            print(f"    [!] Error al obtener perfil: Status {res.status_code}")
    except Exception as e:
        print(f"    [!] Error en requests: {e}")

    return perfil_info

async def extraer_contenido_dinamico():
    """EXTRAE LIKES Y COMENTARIOS REALES USANDO PLAYWRIGHT"""
    print(f"\n[2] Iniciando Playwright para extraer contenido de las publicaciones...")
    posts_data = []

    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True)
        context = await browser.new_context()
        await context.add_cookies([{"name": "sessionid", "value": SESSION_ID, "domain": ".instagram.com", "path": "/"}])
        page = await context.new_page()

        await page.goto(f"https://www.instagram.com/{USERNAME}/")
        await page.wait_for_timeout(3000)

        # Enlaces a los primeros 10 posts
        enlaces = await page.locator('a[href*="/p/"]').evaluate_all('elements => elements.map(e => e.href)')
        enlaces = enlaces[:10]

        for idx, url in enumerate(enlaces):
            await page.goto(url)
            await page.wait_for_timeout(4000)

            # Extraer el bloque de texto completo del post
            try:
                cuerpo_post = await page.locator('article').inner_text(timeout=5000)
            except:
                cuerpo_post = await page.locator('main').inner_text()

            # Limpieza y filtrado
            lineas = [l.strip() for l in cuerpo_post.split('\n') if l.strip()]

            # Filtros de ruido
            palabras_sistema = ['Me gusta', 'Responder', 'Ver traducción', 'Compartir', 'Guardar', 'Also from Meta', 'Follow', 'Seguir', 'Reply']

            comentarios_finales = []
            likes = 'Oculto'

            for linea in lineas:
                if 'Me gusta' in linea or 'likes' in linea:
                    if likes == 'Oculto' and 'Le gusta a' not in linea:
                        likes = linea

                # Ignorar basura, tu usuario y fechas
                if linea in palabras_sistema or linea == USERNAME or linea.startswith('Le gusta a'): continue
                if re.match(r'^\d+[smhdw]$', linea): continue
                if re.match(r'^(January|February|March|April|May|June|July|August|September|October|November|December|Enero|Febrero|Marzo|Abril|Mayo|Junio|Julio|Agosto|Septiembre|Octubre|Noviembre|Diciembre)', linea, re.IGNORECASE): continue

                comentarios_finales.append(linea)

            # Quitamos la descripción (tu comentario original)
            if comentarios_finales:
                comentarios_finales.pop(0)

            posts_data.append({
                'tipo_dato': f'Publicación {idx+1}',
                'post_url': url,
                'detalle': f'Interacciones: {likes}',
                'comment_1': comentarios_finales[0] if len(comentarios_finales) > 0 else 'Sin comentarios',
                'comment_2': comentarios_finales[1] if len(comentarios_finales) > 1 else 'Sin comentarios',
                'comment_3': comentarios_finales[2] if len(comentarios_finales) > 2 else 'Sin comentarios'
            })
            print(f"    ✓ Publicación {idx+1}/10 procesada.")

        await browser.close()
        return posts_data

async def ejecutar_scrapper():
    # Paso 1: Perfil (Requests)
    datos_perfil = obtener_perfil_requests()
    # Paso 2: Posts (Playwright)
    datos_posts = await extraer_contenido_dinamico()

    total_data = datos_perfil + datos_posts

    if total_data:
        nombre_archivo = f'{USERNAME}_entrega_final.csv'
        with open(nombre_archivo, 'w', newline='', encoding='utf-8') as f:
            columnas = ['tipo_dato', 'post_url', 'detalle', 'comment_1', 'comment_2', 'comment_3']
            writer = csv.DictWriter(f, fieldnames=columnas)
            writer.writeheader()
            for fila in total_data:
                writer.writerow(fila)

        print(f"\n[ÉXITO] Archivo generado para entrega: {nombre_archivo}")

# Iniciar proceso
await ejecutar_scrapper()
